{
  "doctype": "DocType",
  "name": "Blood Test Result",
  "module": "Bloodbank",
  "autoname": "format:TEST-{YY}-{####}",
  "creation": "2025-01-01 00:00:00.000000",
  "modified": "2025-01-01 00:00:00.000000",
  "version": 2,
  "issingle": 0,
  "istable": 0,
  "engine": "InnoDB",
  "track_changes": 1,
  "is_submittable": 1,
  "fields": [
    {
      "fieldname": "test_id",
      "label": "Test ID",
      "fieldtype": "Data",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "collection_info",
      "label": "Collection Information",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "blood_collection",
      "label": "Blood Collection",
      "fieldtype": "Link",
      "options": "Blood Collection",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "blood_bag_number",
      "label": "Blood Bag Number",
      "fieldtype": "Data",
      "fetch_from": "blood_collection.blood_bag_number",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "donor",
      "label": "Donor",
      "fieldtype": "Link",
      "options": "Donor",
      "fetch_from": "blood_collection.donor",
      "read_only": 1
    },
    {
      "fieldname": "column_break_1",
      "label": "",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "test_date",
      "label": "Test Date",
      "fieldtype": "Date",
      "default": "Today",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "tested_by",
      "label": "Tested By",
      "fieldtype": "Link",
      "options": "User",
      "reqd": 1
    },
    {
      "fieldname": "mandatory_tests",
      "label": "Mandatory Screening",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "hiv_status",
      "label": "HIV I/II",
      "fieldtype": "Select",
      "options": "Non-Reactive\nReactive\nInvalid",
      "default": "Non-Reactive",
      "reqd": 1
    },
    {
      "fieldname": "hbv_status",
      "label": "HBsAg (HBV)",
      "fieldtype": "Select",
      "options": "Non-Reactive\nReactive\nInvalid",
      "default": "Non-Reactive",
      "reqd": 1
    },
    {
      "fieldname": "hcv_status",
      "label": "Anti-HCV (HCV)",
      "fieldtype": "Select",
      "options": "Non-Reactive\nReactive\nInvalid",
      "default": "Non-Reactive",
      "reqd": 1
    },
    {
      "fieldname": "syphilis_status",
      "label": "Syphilis (VDRL/TPHA)",
      "fieldtype": "Select",
      "options": "Non-Reactive\nReactive\nInvalid",
      "default": "Non-Reactive",
      "reqd": 1
    },
    {
      "fieldname": "malaria_status",
      "label": "Malaria",
      "fieldtype": "Select",
      "options": "Negative\nPositive\nInvalid",
      "default": "Negative",
      "reqd": 1
    },
    {
      "fieldname": "column_break_2",
      "label": "",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "blood_group_conf",
      "label": "Confirmatory Blood Group",
      "fieldtype": "Link",
      "options": "Blood Group",
      "reqd": 1
    },
    {
      "fieldname": "rh_conf",
      "label": "Confirmatory Rh Factor",
      "fieldtype": "Select",
      "options": "Positive\nNegative",
      "reqd": 1
    },
    {
      "fieldname": "additional_tests",
      "label": "Additional Tests",
      "fieldtype": "Table",
      "options": "Additional Test Result"
    },
    {
      "fieldname": "overall_status",
      "label": "Overall Assessment",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "overall_result",
      "label": "Overall Result",
      "fieldtype": "Select",
      "options": "Pending\nPassed\nFailed",
      "default": "Pending",
      "read_only": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "rejection_reason",
      "label": "Rejection Reason",
      "fieldtype": "Small Text",
      "depends_on": "eval:doc.overall_result=='Failed'"
    },
    {
      "fieldname": "notes",
      "label": "Lab Notes",
      "fieldtype": "Text"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "permlevel": 0,
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Blood Bank Manager",
      "permlevel": 0,
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Blood Bank Technician",
      "permlevel": 0,
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 1,
      "cancel": 0
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC",
  "naming_rule": "Expression",
  "title_field": "test_id"
}
